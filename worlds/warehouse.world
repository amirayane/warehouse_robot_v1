    <pose>15 0 2 0 0 0</pose>
  </model>

  <!-- ================= SHELVES ================= -->

  <!-- Left Shelf -->
  <model name="shelf_left">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <box>
            <size>1 8 2.5</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>1 8 2.5</size>
          </box>
        </geometry>

        <material>
          <ambient>0.2 0.35 0.7 1</ambient>
          <diffuse>0.25 0.4 0.8 1</diffuse>
        </material>

      </visual>

    </link>

    <pose>-7 0 1.25 0 0 0</pose>
  </model>

  <!-- Right Shelf -->
  <model name="shelf_right">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <box>
            <size>1 8 2.5</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>1 8 2.5</size>
          </box>
        </geometry>

        <material>
          <ambient>0.2 0.35 0.7 1</ambient>
          <diffuse>0.25 0.4 0.8 1</diffuse>
        </material>

      </visual>

    </link>

    <pose>7 0 1.25 0 0 0</pose>
  </model>

  <!-- ================= BOXES ================= -->

  <model name="cargo_box_1">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <box>
            <size>0.7 0.7 0.7</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.7 0.7 0.7</size>
          </box>
        </geometry>

        <material>
          <ambient>0.7 0.45 0.2 1</ambient>
          <diffuse>0.75 0.5 0.25 1</diffuse>
        </material>

      </visual>

    </link>

    <pose>10 6 0.35 0 0 0</pose>
  </model>

  <model name="cargo_box_2">
    <static>true</static>

    <link name="link">

      <collision name="collision">
        <geometry>
          <box>
            <size>0.7 0.7 0.7</size>
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.7 0.7 0.7</size>
          </box>
        </geometry>

        <material>
          <ambient>0.7 0.45 0.2 1</ambient>
          <diffuse>0.75 0.5 0.25 1</diffuse>
        </material>

