<?xml version="1.0"?>
<robot name="warehouse_robot">

  <!-- ========== BASE / BODY ========== -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.4 0.15"/></geometry>
      <material name="blue"><color rgba="0.1 0.3 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.4 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ========== WHEELS ========== -->
  <link name="front_left_wheel">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.15 0.22 -0.05" rpy="1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.15 -0.22 -0.05" rpy="1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="back_left_wheel">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="back_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_left_wheel"/>
    <origin xyz="-0.15 0.22 -0.05" rpy="1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="back_right_wheel">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="back_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="back_right_wheel"/>
    <origin xyz="-0.15 -0.22 -0.05" rpy="1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ========== ARM BASE ========== -->
  <link name="arm_base">
    <visual>
      <geometry><box size="0.08 0.08 0.12"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>
  <joint name="arm_base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0.15 0 0.13"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== ARM LINK 1 (lower arm) ========== -->
  <link name="arm_link1">
    <visual>
      <geometry><box size="0.06 0.06 0.25"/></geometry>
      <material name="orange"><color rgba="1.0 0.5 0.0 1"/></material>
    </visual>
  </link>
  <joint name="arm_joint1" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.18"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== ARM LINK 2 (upper arm) ========== -->
  <link name="arm_link2">
    <visual>
      <geometry><box size="0.05 0.05 0.20"/></geometry>
      <material name="orange"><color rgba="1.0 0.5 0.0 1"/></material>
    </visual>
  </link>
  <joint name="arm_joint2" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- ========== GRIPPER ========== -->
  <link name="gripper">
    <visual>
      <geometry><box size="0.10 0.04 0.04"/></geometry>
      <material name="red"><color rgba="0.9 0.1 0.1 1"/></material>
    </visual>
  </link>
  <joint name="gripper_joint" type="prismatic">
    <parent link="arm_link2"/>
    <child link="gripper"/>
    <origin xyz="0 0 0.22"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.05" effort="5" velocity="0.5"/>
  </joint>

</robot>